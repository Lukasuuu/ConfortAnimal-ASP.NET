@page
@model LoginModel

@{
    ViewData["Title"] = "Bem-Vindo ao ConfortAnimal 🐄";
}

<h1 style="color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <div class="glass-box">
            <form id="account" method="post">
                <h2 class="glass-text" style="font-weight: 600;">🔑 Entre com sua conta</h2>
                <hr class="glass-hr" />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Identifier" class="form-control glass-input" autocomplete="username" aria-required="true" placeholder="" />
                    <label asp-for="Input.Identifier" class="glass-label">📧 Email ou Username</label>
                    <span asp-validation-for="Input.Identifier" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Password" class="form-control glass-input" autocomplete="current-password" aria-required="true" placeholder="" />
                    <label asp-for="Input.Password" class="glass-label">🔒 Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button id="login-submit" type="submit" class="btn btn-lg glass-btn">✅ Entrar</button>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-lg glass-btn">📝 Criar conta</a>
                </div>

                <div class="mt-3 text-center">
                    <a id="forgot-password" asp-page="./ForgotPassword" class="glass-text-muted">Esqueceu a Palavra-Passe?</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}