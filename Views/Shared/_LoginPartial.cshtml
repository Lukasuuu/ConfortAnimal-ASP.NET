@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <span class="nav-link" style="color: rgba(255,255,255,0.8);">
                👤 @User.Identity?.Name
            </span>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link" style="color: rgba(255,100,100,0.9);">🚪 Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" style="color: rgba(255,255,255,0.8);" asp-area="Identity" asp-page="/Account/Register">📝 Registar</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" style="color: rgba(255,255,255,0.8);" asp-area="Identity" asp-page="/Account/Login">🔑 Login</a>
        </li>
    }
</ul>